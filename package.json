{
  "name": "dothaven",
  "version": "0.4.0",
  "description": "Collect, backup, restore, scan, and diff machine configs across machines",
  "type": "module",
  "bin": {
    "dotfiles": "./bin/dotfiles.ts"
  },
  "scripts": {
    "test": "bun test",
    "format": "biome format --write src tests bin",
    "lint": "biome lint src tests bin",
    "check": "biome check src tests bin",
    "prepublishOnly": "bun test",
    "bump:patch": "npm version patch",
    "bump:minor": "npm version minor",
    "bump:major": "npm version major",
    "release:patch": "bun run bump:patch && bash setup/publish.sh",
    "release:minor": "bun run bump:minor && bash setup/publish.sh",
    "release:major": "bun run bump:major && bash setup/publish.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "files": [
    "bin/dotfiles.ts",
    "src/"
  ],
  "keywords": [
    "dotfiles",
    "cli",
    "config",
    "machine-state",
    "sync"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doguyilmaz/dothaven.git"
  },
  "homepage": "https://doguyilmaz.github.io/dothaven",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "mermaid": "^11.14.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
