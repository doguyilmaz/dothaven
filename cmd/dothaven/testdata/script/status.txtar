# status summarizes the latest backup (in ~/.local/share/dothaven) against the live machine
exec dothaven status
stdout 'Last backup:'
stdout 'files tracked:'
stdout 'backup-box-20240101000000'

-- .zshrc --
alias ll='ls -la'
-- .local/share/dothaven/backup-box-20240101000000/shell/.zshrc --
alias ll='ls -la'
